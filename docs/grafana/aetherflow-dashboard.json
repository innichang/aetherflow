{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping /actuator/prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "title": "AetherFlow",
  "uid": "aetherflow-overview",
  "description": "Operational dashboard for the AetherFlow workflow engine. Requires /actuator/prometheus to be scraped by Prometheus.",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "tags": ["aetherflow", "workflows"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(aetherflow_workflows_started_total, workflow_name)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Workflow",
        "multi": true,
        "name": "workflow_name",
        "options": [],
        "query": {
          "query": "label_values(aetherflow_workflows_started_total, workflow_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(aetherflow_step_duration_seconds{workflow_name=~\"$workflow_name\"}, step_name)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Step",
        "multi": true,
        "name": "step_name",
        "options": [],
        "query": {
          "query": "label_values(aetherflow_step_duration_seconds{workflow_name=~\"$workflow_name\"}, step_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Workflows Started",
      "description": "Total workflows started in the selected time range.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(aetherflow_workflows_started_total{workflow_name=~\"$workflow_name\"}[$__range]))",
          "legendFormat": "started",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Workflows Completed",
      "description": "Workflows that finished successfully in the selected time range.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(aetherflow_workflows_completed_total{status=\"completed\",workflow_name=~\"$workflow_name\"}[$__range]))",
          "legendFormat": "completed",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Workflows Failed",
      "description": "Workflows that ended in failure in the selected time range.",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(aetherflow_workflows_completed_total{status=\"failed\",workflow_name=~\"$workflow_name\"}[$__range]))",
          "legendFormat": "failed",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Workers",
      "description": "Number of worker instances currently registered and active.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "aetherflow_workers_active",
          "legendFormat": "workers",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Throughput & Queue",
      "type": "row"
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Task Throughput",
      "description": "Rate of tasks completing (successful and failed) per second, by workflow and step.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (workflow_name, status) (rate(aetherflow_tasks_completed_total{workflow_name=~\"$workflow_name\",step_name=~\"$step_name\"}[$__rate_interval]))",
          "legendFormat": "{{workflow_name}} / {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Queue Depth",
      "description": "Live count of tasks in the queue by status (pending = waiting, running = claimed by a worker).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pending" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byName", "options": "running" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "aetherflow_queue_depth",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Latency",
      "type": "row"
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Step Execution Latency (p50 / p95 / p99)",
      "description": "Client-side percentile estimates for step execution time. Use the Step variable to drill into a specific step.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "unit": "s",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "aetherflow_step_duration_seconds{quantile=\"0.5\",workflow_name=~\"$workflow_name\",step_name=~\"$step_name\",status=\"completed\"}",
          "legendFormat": "p50 · {{workflow_name}} / {{step_name}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "aetherflow_step_duration_seconds{quantile=\"0.95\",workflow_name=~\"$workflow_name\",step_name=~\"$step_name\",status=\"completed\"}",
          "legendFormat": "p95 · {{workflow_name}} / {{step_name}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "aetherflow_step_duration_seconds{quantile=\"0.99\",workflow_name=~\"$workflow_name\",step_name=~\"$step_name\",status=\"completed\"}",
          "legendFormat": "p99 · {{workflow_name}} / {{step_name}}",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 103,
      "title": "Reliability",
      "type": "row"
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Retry Rate",
      "description": "Rate of step retry events per second. A sustained non-zero rate indicates recurring failures on specific steps.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "orange" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (workflow_name, step_name) (rate(aetherflow_tasks_retried_total{workflow_name=~\"$workflow_name\",step_name=~\"$step_name\"}[$__rate_interval]))",
          "legendFormat": "{{workflow_name}} / {{step_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Workflow Completion Rate (success vs failure)",
      "description": "Rate of workflows finishing per second, split by outcome. A rising failure series warrants investigation.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "reqps",
          "min": 0,
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "FAIL" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "OK" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (workflow_name) (rate(aetherflow_workflows_completed_total{status=\"completed\",workflow_name=~\"$workflow_name\"}[$__rate_interval]))",
          "legendFormat": "✓ {{workflow_name}}",
          "refId": "OK"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (workflow_name) (rate(aetherflow_workflows_completed_total{status=\"failed\",workflow_name=~\"$workflow_name\"}[$__rate_interval]))",
          "legendFormat": "✗ {{workflow_name}}",
          "refId": "FAIL"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 104,
      "title": "Per-Workflow Breakdown",
      "type": "row"
    },
    {
      "id": 10,
      "type": "table",
      "title": "Step Totals by Workflow",
      "description": "Aggregate step completion counts and total retry count per workflow. Helps spot which workflows are most active or most error-prone.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "Completed", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true },
          "color": { "mode": "thresholds" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Retried" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "transparent", "value": null },
                    { "color": "orange", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "Completed",
              "Value #B": "Failed",
              "Value #C": "Retried",
              "workflow_name": "Workflow"
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (workflow_name) (increase(aetherflow_tasks_completed_total{status=\"completed\",workflow_name=~\"$workflow_name\"}[$__range]))",
          "legendFormat": "{{workflow_name}}",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (workflow_name) (increase(aetherflow_tasks_completed_total{status=\"failed\",workflow_name=~\"$workflow_name\"}[$__range]))",
          "legendFormat": "{{workflow_name}}",
          "refId": "B",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (workflow_name) (increase(aetherflow_tasks_retried_total{workflow_name=~\"$workflow_name\"}[$__range]))",
          "legendFormat": "{{workflow_name}}",
          "refId": "C",
          "instant": true
        }
      ]
    }
  ]
}
